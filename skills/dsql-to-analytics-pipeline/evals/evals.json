{
  "skill_name": "dsql-to-analytics-pipeline",
  "evals": [
    {
      "id": 0,
      "eval_name": "real-time-dsql-to-redshift-pipeline",
      "prompt": "Build a real-time DSQL to Redshift pipeline. I have an Aurora DSQL cluster with orders, customers, and order_items tables and I want to analyze them in Redshift Serverless with low latency.",
      "expected_output": "Recommends DSQL CDC stream -> Kinesis -> Lambda -> Redshift Serverless with an append-only cdc_events log and ROW_NUMBER reconstruction views, not in-place upserts.",
      "assertions": [
        {
          "text": "Recommends the DSQL CDC stream as the source (not polling or app-level dual-writes)",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "CDC stream",
              "cdc stream",
              "DSQL CDC",
              "change data capture",
              "Kinesis"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Recommends an append-only event log (cdc_events table) over in-place upserts",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "append-only",
              "append only",
              "cdc_events",
              "event log"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Reconstructs current state with ROW_NUMBER over commit_timestamp DESC (not MERGE/UPSERT in the hot path)",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "ROW_NUMBER",
              "row_number",
              "PARTITION BY",
              "commit_timestamp",
              "latest commit"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Does NOT propose in-place MERGE/UPSERT as the primary pattern",
          "category": "safety",
          "check": {
            "type": "not_contains",
            "values": [
              "MERGE INTO",
              "primary pattern is upsert",
              "use UPSERT in the Lambda"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Mentions Lambda event source mapping with Kinesis as the consumer",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "event source mapping",
              "EventSourceMapping",
              "Lambda",
              "consumer"
            ]
          },
          "passed": null,
          "evidence": ""
        }
      ]
    },
    {
      "id": 1,
      "eval_name": "missing-update-events-c-and-d-preview",
      "prompt": "Why are my DSQL UPDATE events missing from Redshift? I'm running the CDC pipeline and I see inserts and deletes downstream but no update operations show up in cdc_events.op.",
      "expected_output": "Explains the DSQL CDC preview limitation that both INSERT and UPDATE arrive as op='c' (no 'u'), and shows that the latest-commit-timestamp reconstruction handles this correctly without code changes.",
      "assertions": [
        {
          "text": "Explains DSQL CDC preview emits only c and d ops (no u)",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "only c and d",
              "c' and 'd",
              "no 'u'",
              "no u op",
              "INSERT and UPDATE arrive as",
              "both INSERT and UPDATE",
              "preview"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Clarifies UPDATE shows up as op='c', not as a missing event",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "as 'c'",
              "as c",
              "op='c'",
              "op = 'c'",
              "create",
              "treated as create"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Explains the latest-commit-timestamp reconstruction correctly handles c-as-update",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "ROW_NUMBER",
              "row_number",
              "commit_timestamp",
              "latest",
              "most recent",
              "DESC"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Does NOT recommend filtering for op='u' or treating updates as a bug to file",
          "category": "safety",
          "check": {
            "type": "not_contains",
            "values": [
              "filter for op='u'",
              "filter op = 'u'",
              "WHERE op = 'u'"
            ]
          },
          "passed": null,
          "evidence": ""
        }
      ]
    },
