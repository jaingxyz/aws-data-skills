    {
      "id": 3,
      "eval_name": "lake-formation-grants-before-firehose",
      "prompt": "I'm getting AccessDenied on glue:GetTable when creating my Firehose stream. The Firehose role already has glue:GetTable in its IAM policy. What am I missing?",
      "expected_output": "Identifies that Lake Formation governs S3 Tables, so IAM policies are not enough. Requires LF DESCRIBE/SELECT/INSERT grants on the table to the Firehose role before stream creation. Mentions the lf_grant pattern.",
      "assertions": [
        {
          "text": "Identifies that Lake Formation, not just IAM, governs access to S3 Tables",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "Lake Formation",
              "LakeFormation",
              "LF",
              "lakeformation",
              "Lake Formation governs",
              "LF governs"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
