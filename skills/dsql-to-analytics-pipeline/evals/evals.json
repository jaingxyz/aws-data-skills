        {
          "text": "Does NOT recommend swallowing exceptions or logging-and-continuing on FAILED",
          "category": "safety",
          "check": {
            "type": "not_contains",
            "values": [
              "swallow the exception",
              "log and continue",
              "ignore the error",
              "except: pass"
            ]
          },
          "passed": null,
