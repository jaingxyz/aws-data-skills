{
  "skill_name": "streaming-into-data-lake",
  "evals": [
    {
      "id": 0,
      "eval_name": "firehose-kinesis-to-s3-tables-iceberg",
      "prompt": "Set up a Firehose pipeline to write to S3 Tables Iceberg. Source is a Kinesis Data Stream called 'orders-stream'. Target is an Iceberg table 'orders' in the 'sales' namespace of the 'analytics-data' table bucket.",
      "expected_output": "Walks through preconditions (table exists, LF admin, region supported), surfaces the column-mapping footgun, requires a transform Lambda for DestinationDatabaseName/DestinationTableName metadata, and recommends the three-phase deploy (table + LF grants -> stream -> source binding).",
      "assertions": [
        {
          "text": "Surfaces the Iceberg column-mapping footgun (Firehose cannot route records into Iceberg without per-record routing metadata)",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "column",
              "column-mapping",
              "column mapping",
              "MissingColumn",
              "routing metadata",
              "DestinationDatabaseName",
              "DestinationTableName"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Requires a transform Lambda to inject routing metadata before delivery",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "transform Lambda",
              "transformation Lambda",
              "ProcessingConfiguration",
              "Lambda transform",
              "data transformation"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Recommends a three-phase deploy (table + LF grants first, then Firehose stream, then source binding)",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "three-phase",
              "three phase",
              "phase 1",
              "phase 2",
              "phase 3",
              "EnableFirehose",
              "EnableFirehoseStream"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Verifies the Iceberg table already exists before creating the stream",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "table exists",
              "GetTable",
