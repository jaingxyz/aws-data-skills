    {
      "id": 4,
      "eval_name": "consumer-lambda-silently-dropping-records",
      "prompt": "My DSQL CDC consumer Lambda looks like it's silently dropping records. Kinesis advances past data that never lands in Redshift. The Lambda logs show no errors. What did I get wrong?",
      "expected_output": "Identifies the async nature of execute_statement, explains that describe_statement must be polled until FINISHED, and that FAILED/ABORTED must re-raise so Kinesis retries the batch.",
      "assertions": [
        {
          "text": "Identifies execute_statement as async (returns a statement Id, not the result)",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "execute_statement is async",
              "asynchronous",
              "returns immediately",
              "statement Id",
              "statement id",
              "fire and forget"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Recommends polling describe_statement until each chunk reaches FINISHED",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "describe_statement",
              "DescribeStatement",
              "poll",
              "FINISHED"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Recommends raising on FAILED/ABORTED so Kinesis retries the batch",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "FAILED",
              "ABORTED",
              "raise",
              "re-raise",
              "retry",
              "Kinesis retries",
              "event source mapping retries"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Warns that skipping the poll lets Kinesis advance past lost data (silent data loss)",
          "category": "safety",
          "check": {
            "type": "contains_any",
            "values": [
              "silent",
              "advance past",
              "data loss",
              "lost data",
