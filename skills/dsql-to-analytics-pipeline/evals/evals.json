    {
      "id": 3,
      "eval_name": "redshift-data-api-200-param-limit",
      "prompt": "My Lambda is failing with 'Number of parameters in statement exceeds maximum allowed (200)' when writing CDC events to Redshift. What's going on and how do I fix it?",
      "expected_output": "Explains the Redshift Data API 200-parameter-per-statement cap, shows the chunking math (200 / params_per_row), and recommends ROWS_PER_CHUNK at or below that ceiling.",
      "assertions": [
        {
          "text": "Identifies the Redshift Data API 200-parameter cap as the root cause",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "200 parameter",
              "200-parameter",
              "200 params",
              "parameter limit",
              "parameter cap",
              "max 200"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Shows the chunking math: 200 / params_per_row",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "200 / ",
              "200/",
              "params_per_row",
              "params per row",
              "MAX_PARAMS_PER_STATEMENT",
              "ROWS_PER_CHUNK"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Recommends lowering ROWS_PER_CHUNK or chunking the batch before execute_statement",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
              "ROWS_PER_CHUNK",
              "chunk",
              "lower the batch",
              "smaller batch",
              "split"
            ]
          },
          "passed": null,
          "evidence": ""
        },
        {
          "text": "Does NOT recommend raising the limit (it is a hard service limit) or string-concatenating values to dodge it",
          "category": "safety",
          "check": {
            "type": "not_contains",
            "values": [
              "raise the limit",
              "request a higher limit",
              "concatenate values",
              "string concatenation",
              "f-string the SQL"
            ]
          },
          "passed": null,
          "evidence": ""
        }
      ]
