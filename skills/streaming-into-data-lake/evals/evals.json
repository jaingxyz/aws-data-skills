    {
      "id": 2,
      "eval_name": "iceberg-timestamp-microsecond-conversion",
      "prompt": "My Iceberg timestamps are wrong. Source records carry an event_time field as Unix epoch milliseconds, but the values in the Iceberg table look like they're around 1970. What gives?",
      "expected_output": "Identifies that Iceberg timestamp values are microseconds since epoch, not milliseconds. Recommends multiplying ms x 1000 in the transform Lambda before delivery.",
      "assertions": [
        {
          "text": "Identifies that Iceberg expects microseconds since epoch, not milliseconds",
          "category": "correctness",
          "check": {
            "type": "contains_any",
            "values": [
